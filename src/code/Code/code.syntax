namespace : OwlDomain.Owl.Code.CodeAnalysis.Syntax

# Define the shadowing
shadow : concrete declared semantic annotated

# Define what's on the tokens
token concrete
token declared
token semantic
token annotated

# Define the trees, and what each node in that tree can have
tree concrete
tree declared
tree semantic
tree annotated

# Defines the root node of the tree
document : list<statement> statements, token end_of_input

## Type names
group type
type @ declared : IType type_info
empty type
regular type : token name
regular_type @ declared : ISymbolGroup symbols
nested type : type left, token dot, token name
generic type : type type, token start, list<type, token> generics, token end

## Statements
group statement
only_terminated statement : token terminator
empty statement
block statement        : token start, list<statement> statements, token end
expression statement   : expression expression, token terminator
if statement           : token keyword, token start, expression condition, token end, expression true_clause
if_else statement      : token keyword, token start, expression condition, token end, statement true_clause, token else, statement false_clause
while statement        : token keyword, token start, expression condition, token end, statement body
return statement       : token keyword, token terminator
value_return statement : token keyword, expression value, token terminator

### Declarations
variable_declaration statement        : type type, token name, token assignment, expression value, token terminator
variable_declaration @ declared       : IDeclaredLocalVariable variable

#### Functions
function_declaration statement        : token name, token start, list<function_parameter, token> parameters, token end, function_return return, function_body body
function_declaration @ declared       : IDeclaredFunction function, ISymbolScope scope
local_function_declaration statement  : token keyword, function_declaration_statement declaration

group function_parameter : token name
function_parameter @ declared : IDeclaredFunctionParameter parameter
regular function_parameter : type type

group function_return
empty function_return
regular function_return : token colon, type return_type

group function_body
only_terminated function_body : token terminator
empty function_body
short function_body : token arrow, expression expression, token terminator
block function_body : block_statement block

## Expressions
group expression
expression @ semantic : IType result_type
empty expression
binary expression     : expression left, token operator, expression right
ternary expression    : expression condition, token question, expression true_clause, token colon, expression false_clause
grouped expression    : token start, expression value, token end
get expression        : token name
get @ semantic        : ISymbol symbol

### Literals
boolean_literal expression : token token

#### Strings
group string_fragment
string_literal expression      : token start, list<string_fragment> fragments, token end, string value
interpolated_string expression : token start, list<string_fragment> fragments, token end

regular string_fragment        : token text
escaped_hex string_fragment    : token sequence
escaped string_fragment        : token sequence
interpolated string_fragment   : token start, expression value, token end

#### Numbers
base_integer_literal expression : token base, token integer
integer_literal expression      : token integer
decimal_literal expression      : token integer, token dot, token decimal, decimal? value

### Functions
function_call expression : expression expression, token start, list<function_argument, token> arguments, token end
function_call @ semantic : ICallableType? callable

group function_argument
regular function_argument : expression value
named function_argument  : token name, token separator, expression value
