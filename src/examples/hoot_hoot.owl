// "Hoot Hoot" examples (an OWL equivalent to "Hello World").

// Direct (print will most definitely be removed later).
println("Hoot Hoot!");

// From variable
text output = "Hoot Hoot (from variable)!";
println(output);

// From function
HootTheUser("<user>");

// 'fun' is only required for local / top-level function declarations
fun HootTheUser(text user)
{
	// Using named parameter
	text output = GetHootText(target: user);
	println(output);
}

// Showing off function body shorthand syntax.
fun GetHootText(text target): text => $"Hoot Hoot {target}!";
